                                        "name": "BreakAttackSequenceTimeout"
                                    },
                                    {
                                        "type": "Action",
                                        "name": "AOEAttackAnimation"
                                    },
                                    {
                                        "type": "Action",
                                        "name": "PreAttackTimeout"
                                    },
                                    {
                                        "type": "Action",
                                        "name": "AOEAttackTarget"
                                    },
                                    {
